{
  "rewrites": [
    { "source": "/api/chat",      "destination": "/api/chat"      },
    { "source": "/api/upload",    "destination": "/api/upload"    },
    { "source": "/api/image",     "destination": "/api/image"     },
    { "source": "/api/tts",       "destination": "/api/tts"       },
    { "source": "/api/sentiment", "destination": "/api/sentiment" },
    { "source": "/api/summarize", "destination": "/api/summarize" },
    { "source": "/api/health",    "destination": "/api/health"    },
    { "source": "/(.*)",          "destination": "/public/$1"     }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Cache-Control",                "value": "no-store" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
